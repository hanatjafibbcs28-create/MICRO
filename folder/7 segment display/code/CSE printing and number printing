CSE PRINT:	
	OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
START:
        MOV AX,DATA
        MOV DS,AX
        MOV AL,80H
        MOV DX,FFE6H
        OUT DX,AL
REPEAT:
        MOV AL,39H
        MOV DX,FFE0H
        OUT DX,AL
        MOV AL,6BH
        MOV DX,FFE2H
        OUT DX,AL
        MOV AL,79H
        MOV DX,FFE4H
        OUT DX,AL
        CALL DELAY
        MOV AL,00H
        MOV DX,FFE0H
        OUT DX,AL
        MOV AL,00H
        MOV DX,FFE2H
        OUT DX,AL
        MOV AL,00H
        MOV DX,FFE4H
        OUT DX,AL
        CALL DELAY
        JMP REPEAT
DELAY:
        MOV AH,15H
D4:
        MOV BX,AAAAH
D5:
        DEC BX
        JNZ D5
        DEC AH
        JNZ D4
        RET

CODE ENDS
END


    
SINGLE DIGIT:

		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
LIST DB 3FH,06H,5BH,4FH,66H,6DH,7DH,27H,7FH,6FH,77H,7CH,39H,5EH,79H,71H
COUNT DB  10H
DATA ENDS
CODE SEGMENT 
	ASSUME CS:CODE,DS:DATA,ES:DATA
START:
		MOV AX,DATA
		MOV DS,AX
		MOV AL,80H
		MOV DX,FFE6H
		OUT DX,AL
REPEAT:
		MOV SI,OFFSET LIST
		MOV CL,COUNT
L1:
		MOV Al,[SI]
		MOV DX,FFE0H
		OUT DX,AL
		CALL DELAY
		INC SI
		DEC CL
		JNZ L1
		JMP REPEAT
DELAY:
		MOV AH,15H
L3:
		MOV BX,AAAAH
L2:
		DEC BX
		JNZ L2
		DEC AH
		JNZ L3
		RET
CODE ENDS
ENDS


    
DOUBLE DIGIT:

				OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
LIST1 DB 06H,7CH,39H
LIST2 DB 06H,79H,6DH
COUNT DB 03H
DATA ENDS
CODE SEGMENT
	ASSUME CS:CODE,DS:DATA
START: MOV AX,DATA
	   MOV DS,AX
	   MOV AL,80H
	   MOV DX,FFE6H
	   OUT DX,AL
REPEAT:LEA SI,LIST1
	   MOV CL,03H
L2:    MOV AL,[SI]
	   MOV DX,FFE6H
	   OUT DX,AL
	   LEA DI,LIST2
	   MOV CH,03H
L1:    MOV AL,[DI]
	   MOV DX,FFE2H
	   OUT DX,AL
	   CALL DELAY
	   INC DI
	   DEC CH
	   JNZ L1
	   INC SI
	   DEC CL
	   JNZ L2
	   JMP REPEAT
DELAY: MOV AH,15H
L4:    MOV BX,AAAAH
L3:    DEC BX
	   JNZ L3
	   DEC AH
	   JNZ L4
	   RET
CODE ENDS
END

