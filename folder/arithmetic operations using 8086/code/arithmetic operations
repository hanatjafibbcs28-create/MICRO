Power of n:
                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
X DB 02H
N DB 03H
RES DW 0000H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV CL,N
        MOV AL,01H
        MOV CL,N
        MOV BL,X
L1:
        MUL BL
        DEC CL
        JNZ L1
        MOV RES,AX
CODE ENDS
END          
