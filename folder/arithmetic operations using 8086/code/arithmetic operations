Addition:
                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
NO1 DW AAAAH
NO2 DW BBBBH
SUM DW 0000H
CARRY DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV CL,00H
        MOV AX,NO1
        ADD AX,NO2
        JNC L1
        INC CL
L1: MOV SUM,AX
        MOV CARRY,CL
CODE ENDS



                  
