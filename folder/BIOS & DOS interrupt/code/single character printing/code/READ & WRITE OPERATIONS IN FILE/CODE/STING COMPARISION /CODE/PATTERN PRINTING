        INT 21H
        MOV AH,3EH
        INT 21H
        MOV AH,3DH
        MOV DX,OFFSET FN
        INT 21H
        MOV BX,AX
        MOV AH,3FH
        MOV DX,OFFSET BUFFER
        MOV CX,21H
        INT 21H
        MOV AH,09H
        MOV BX,OFFSET BUFFER
        INT 21H
        MOV AH,4CH
        INT 21H
CODE ENDS
END

STRING COMPARE IN INTERRUPTS:

DATA SEGMENT
STR1 DB "AAAA"
STR2 DB "AAAA"
COUNT DB 04H
OUT1 DB "EQU",'$'
OUT2 DB "NOT",'$'
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA,ES:DATA
START:  MOV AX,DATA
        MOV DS,AX
        MOV ES,AX
        MOV SI,OFFSET STR1
        MOV DI,OFFSET STR2
        MOV BL,COUNT
        CLD
L2:     CMPSB
        JZ L1
        JMP L3
L1:     DEC BL
        JNZ L2
        MOV AH,09H
        MOV DX,OFFSET OUT1
        INT 21H
        JMP L4
L3:     MOV AH,09H
        MOV AX,OFFSET OUT2
        INT 21H
L4:     MOV AH,4CH
        INT 21H
CODE ENDS
END


